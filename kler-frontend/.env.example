# KLER Frontend - Környezeti változók példa fájl
# Másold le ezt a fájlt .env néven, és töltsd ki a saját API kulcsoddal!

# Google Gemini API kulcs a mesterséges intelligencia elemzésekhez
# Beszerezhető innen: https://aistudio.google.com/
VITE_GEMINI_API_KEY="Az-en-gemini-api-kulcsom"

# Google Auth Client ID
VITE_GOOGLE_CLIENT_ID="Az-en-google-client-id-em"

# Backend API URL
VITE_API_URL=http://localhost:5173
